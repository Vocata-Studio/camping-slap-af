---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const unsplash = (id: string, w = 1200) =>
  `https://images.unsplash.com/${id}?w=${w}&q=80&auto=format&fit=crop`;

const heroImage = "/images/old-gerlis-placeholder.webp";

const photos = [
  { id: "photo-1504280390367-361c6d9f38f4", altKey: "image1Alt", span: "tall" },
  { id: "photo-1445308394109-4ec2920981b1", altKey: "image2Alt", span: null },
  { id: "photo-1464822759023-fed622ff2c3b", altKey: "image3Alt", span: "wide" },
  { id: "photo-1517824806704-9040b037703b", altKey: "image4Alt", span: null },
  { id: "photo-1496545672447-f699b503d270", altKey: "image5Alt", span: null },
  { id: "photo-1510312305653-8ed496efae75", altKey: "image6Alt", span: "tall" },
  { id: "photo-1518655048521-f130df041f66", altKey: "image7Alt", span: "wide" },
  { id: "photo-1472214103451-9374bd1c798e", altKey: "image8Alt", span: null },
] as const;
---

<Layout title={t(l, "Gallery", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "Gallery", "title")}
    title={t(l, "Gallery", "title")}
    subtitle={t(l, "Gallery", "subtitle")}
    compact
  />

  <section class="section">
    <div class="container">
      <div class="gallery">
        {
          photos.map((photo) => (
            <figure class:list={["gallery__item", photo.span && `gallery__item--${photo.span}`]}>
              <img
                src={unsplash(photo.id, 1000)}
                alt={t(l, "Gallery", photo.altKey)}
                loading="lazy"
              />
            </figure>
          ))
        }
      </div>
      <p class="gallery__note">{t(l, "Gallery", "comingSoon")}</p>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Before & After -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "Gallery", "beforeAfterTitle")}</h2>
        <p>{t(l, "Gallery", "beforeAfterSubtitle")}</p>
      </div>
      <div class="ba-grid">
        <div class="ba-card">
          <div class="ba-card__label">{t(l, "Gallery", "beforeLabel")}</div>
          <div class="ba-card__media">
            <img src="/images/old-gerlis-placeholder.webp" alt={t(l, "Gallery", "beforeLabel")} loading="lazy" />
          </div>
        </div>
        <div class="ba-card">
          <div class="ba-card__label">{t(l, "Gallery", "afterLabel")}</div>
          <div class="ba-card__media ba-card__media--placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
              <circle cx="9" cy="9" r="2" />
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
            </svg>
            <span>{t(l, "Gallery", "afterComingSoon")}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }
  @media (min-width: 960px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 220px;
      gap: var(--space-5);
    }
  }

  .gallery__item {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-cream);
  }
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 960px) {
    .gallery__item img {
      aspect-ratio: auto;
    }
    .gallery__item--wide {
      grid-column: span 2;
    }
    .gallery__item--tall {
      grid-row: span 2;
    }
  }

  .gallery__note {
    margin-top: var(--space-10);
    text-align: center;
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }

  /* Before & After */
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .ba-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .ba-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-white);
  }
  .ba-card__label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-3) var(--space-5);
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .ba-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .ba-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ba-card__media--placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: var(--color-cream);
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }
  .ba-card__media--placeholder svg {
    width: 40px;
    height: 40px;
    color: var(--color-mint);
  }
</style>
