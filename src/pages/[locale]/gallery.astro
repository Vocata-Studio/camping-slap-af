---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const heroImage = "/images/old-gerlis-placeholder.webp";

const photos = [
  { gradient: 1, altKey: "image1Alt", span: "tall" },
  { gradient: 2, altKey: "image2Alt", span: null },
  { gradient: 1, altKey: "image3Alt", span: "wide" },
  { gradient: 2, altKey: "image4Alt", span: null },
  { gradient: 1, altKey: "image5Alt", span: null },
  { gradient: 2, altKey: "image6Alt", span: "tall" },
  { gradient: 1, altKey: "image7Alt", span: "wide" },
  { gradient: 2, altKey: "image8Alt", span: null },
] as const;
---

<Layout title={t(l, "Gallery", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "Gallery", "title")}
    title={t(l, "Gallery", "title")}
    subtitle={t(l, "Gallery", "subtitle")}
    compact
  />

  <section class="section">
    <div class="container">
      <div class="gallery">
        {
          photos.map((photo) => (
            <figure
              class:list={[
                "gallery__item",
                `gallery__item--gradient-${photo.gradient}`,
                photo.span && `gallery__item--${photo.span}`,
              ]}
              role="img"
              aria-label={t(l, "Gallery", photo.altKey)}
            >
              <span class="gallery__item-label">Billede kommer snart</span>
            </figure>
          ))
        }
      </div>
      <p class="gallery__note">{t(l, "Gallery", "comingSoon")}</p>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Before & After -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "Gallery", "beforeAfterTitle")}</h2>
        <p>{t(l, "Gallery", "beforeAfterSubtitle")}</p>
      </div>
      <div class="ba-grid">
        <div class="ba-card">
          <div class="ba-card__label">{t(l, "Gallery", "beforeLabel")}</div>
          <div class="ba-card__media">
            <img src="/images/old-gerlis-placeholder.webp" alt={t(l, "Gallery", "beforeLabel")} loading="lazy" />
          </div>
        </div>
        <div class="ba-card">
          <div class="ba-card__label">{t(l, "Gallery", "afterLabel")}</div>
          <div class="ba-card__media ba-card__media--placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
              <circle cx="9" cy="9" r="2" />
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
            </svg>
            <span>{t(l, "Gallery", "afterComingSoon")}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }
  @media (min-width: 960px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 220px;
      gap: var(--space-5);
    }
  }

  .gallery__item {
    margin: 0;
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-cream);
    aspect-ratio: 4 / 3;
  }
  .gallery__item-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(26, 26, 26, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .gallery__item--gradient-1 {
    background:
      radial-gradient(at 20% 25%, #a8c9a5 0%, transparent 55%),
      radial-gradient(at 80% 80%, #d9e4cf 0%, transparent 60%),
      linear-gradient(135deg, #77BA8A 0%, #2B9854 100%);
  }
  .gallery__item--gradient-2 {
    background:
      radial-gradient(at 75% 20%, #e8d9c0 0%, transparent 55%),
      radial-gradient(at 25% 85%, #9fb8a4 0%, transparent 60%),
      linear-gradient(160deg, #c8b99c 0%, #6b8b6e 100%);
  }

  @media (min-width: 960px) {
    .gallery__item {
      aspect-ratio: auto;
    }
    .gallery__item--wide {
      grid-column: span 2;
    }
    .gallery__item--tall {
      grid-row: span 2;
    }
  }

  .gallery__note {
    margin-top: var(--space-10);
    text-align: center;
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }

  /* Before & After */
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .ba-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .ba-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-white);
  }
  .ba-card__label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-3) var(--space-5);
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .ba-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .ba-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ba-card__media--placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: var(--color-cream);
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }
  .ba-card__media--placeholder svg {
    width: 40px;
    height: 40px;
    color: var(--color-mint);
  }
</style>
