---
import {
  navLinks,
  bookingLink,
  locales,
  localeLabels,
  localePath,
  t,
} from "../i18n/utils";
import type { Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
  /** The route portion without the locale, e.g. "/", "/about" */
  currentRoute: string;
}

const { locale, currentRoute } = Astro.props;

function isActive(href: string): boolean {
  if (href === "/") return currentRoute === "/";
  return currentRoute === href || currentRoute.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={localePath(locale, "/")} class="site-header__brand" aria-label="Camping Slap Af">
      <img
        src="/csa-iconv1.png"
        alt=""
        width="64"
        height="64"
        class="site-header__logo"
      />
      <span class="site-header__wordmark">Camping Slap Af</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={localePath(locale, link.href)}
                class:list={[
                  "site-header__nav-link",
                  { "is-active": isActive(link.href) },
                ]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {t(locale, "Header", link.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <details class="lang-switch">
        <summary aria-label="Change language" class="lang-switch__trigger">
          <img
            src={`/flags/${localeLabels[locale].flagCode}.svg`}
            alt=""
            width="22"
            height="16"
            class="lang-switch__flag"
            aria-hidden="true"
          />
          <span class="visually-hidden">{localeLabels[locale].native}</span>
          <svg
            class="lang-switch__chevron"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <ul class="lang-switch__menu" role="menu">
          {
            locales.map((code) => (
              <li role="none">
                <a
                  role="menuitem"
                  href={localePath(code, currentRoute)}
                  class:list={[
                    "lang-switch__item",
                    { "is-active": code === locale },
                  ]}
                  data-locale={code}
                >
                  <img
                    src={`/flags/${localeLabels[code].flagCode}.svg`}
                    alt=""
                    width="22"
                    height="16"
                    class="lang-switch__flag"
                    aria-hidden="true"
                  />
                  <span class="lang-switch__name">{localeLabels[code].native}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </details>

      <a href={localePath(locale, bookingLink.href)} class="btn site-header__cta">
        {t(locale, "Header", bookingLink.key)}
      </a>

      <details class="menu-toggle">
        <summary aria-label="Open menu" class="menu-toggle__trigger">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </summary>
        <div class="menu-toggle__panel">
          <ul class="menu-toggle__list">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={localePath(locale, link.href)}
                    class:list={[
                      "menu-toggle__link",
                      { "is-active": isActive(link.href) },
                    ]}
                  >
                    {t(locale, "Header", link.key)}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href={localePath(locale, bookingLink.href)}
                class="btn menu-toggle__cta"
              >
                {t(locale, "Header", bookingLink.key)}
              </a>
            </li>
          </ul>
        </div>
      </details>
    </div>
  </div>
</header>

<!-- Persist the language the user is currently viewing so subsequent visits skip detection. -->
<script is:inline>
  try {
    var lang = document.documentElement.lang;
    if (lang) localStorage.setItem("campingslapaf.locale", lang);
  } catch (e) {}
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-hairline);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    min-height: var(--header-h);
  }

  /* Brand */
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-ink);
  }
  .site-header__brand:hover {
    color: var(--color-ink);
  }
  .site-header__logo {
    width: 64px;
    height: 64px;
    object-fit: contain;
  }
  .site-header__wordmark {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  /* Primary nav */
  .site-header__nav {
    display: none;
  }
  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .site-header__nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink);
    padding: var(--space-2) 0;
    position: relative;
  }
  .site-header__nav-link:hover {
    color: var(--color-green);
  }
  .site-header__nav-link.is-active {
    color: var(--color-green);
  }
  .site-header__nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-green);
    border-radius: 2px;
  }

  /* Actions cluster (lang + cta + mobile menu) */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-header__cta {
    display: none;
  }

  /* ----- Language switcher ------------------------------------------ */
  .lang-switch {
    position: relative;
  }
  .lang-switch__trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    background: var(--color-white);
  }
  .lang-switch__trigger:hover {
    border-color: var(--color-green);
    color: var(--color-green);
  }
  .lang-switch__chevron {
    transition: none;
  }
  .lang-switch[open] .lang-switch__chevron {
    transform: rotate(180deg);
  }

  .lang-switch__menu {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 200px;
    padding: var(--space-2);
    background: var(--color-white);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgba(26, 26, 26, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 60;
  }
  .lang-switch__item {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    font-size: var(--fs-sm);
  }
  .lang-switch__item:hover {
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .lang-switch__item.is-active {
    color: var(--color-green);
    background: var(--color-cream);
  }
  .lang-switch__flag {
    display: block;
    width: 18px;
    height: 13px;
    object-fit: cover;
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(26, 26, 26, 0.08);
    flex-shrink: 0;
  }
  .lang-switch__item {
    align-items: center;
  }
  .lang-switch__name {
    font-weight: 500;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ----- Mobile menu toggle ----------------------------------------- */
  .menu-toggle {
    position: relative;
  }
  .menu-toggle__trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-pill);
    color: var(--color-ink);
    background: var(--color-white);
  }
  .menu-toggle__trigger:hover {
    border-color: var(--color-green);
    color: var(--color-green);
  }
  .menu-toggle__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 260px;
    padding: var(--space-3);
    background: var(--color-white);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgba(26, 26, 26, 0.08);
    z-index: 60;
  }
  .menu-toggle__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .menu-toggle__link {
    display: block;
    padding: 0.75rem var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-md);
    font-weight: 500;
    color: var(--color-ink);
  }
  .menu-toggle__link:hover {
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .menu-toggle__link.is-active {
    color: var(--color-green);
  }
  .menu-toggle__cta {
    margin-top: var(--space-3);
    width: 100%;
  }

  /* ---------------------------------------------------------------- */
  /* Desktop                                                            */
  /* ---------------------------------------------------------------- */
  @media (min-width: 960px) {
    .site-header__nav {
      display: block;
    }
    .site-header__cta {
      display: inline-flex;
    }
    .menu-toggle {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .site-header__inner {
      min-height: var(--header-h-mobile);
    }
    .site-header__wordmark {
      display: none;
    }
  }
</style>
