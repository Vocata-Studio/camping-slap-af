---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const unsplash = (id: string, w = 1600) =>
  `https://images.unsplash.com/${id}?w=${w}&q=80&auto=format&fit=crop`;

const heroImage = "/images/old-gerlis-placeholder.webp";

const onSite = [
  { key: "activity1", icon: "playground" },
  { key: "activity2", icon: "fish" },
  { key: "activity3", icon: "flame" },
  { key: "activity4", icon: "circle" },
] as const;

const nearby = [
  { key: "nearby1", image: unsplash("photo-1518655048521-f130df041f66", 900) },
  { key: "nearby2", image: unsplash("photo-1464982326199-86f358bac9e6", 900) },
  { key: "nearby3", image: unsplash("photo-1472214103451-9374bd1c798e", 900) },
  { key: "nearby4", image: unsplash("photo-1507035895480-2b3b7b7b8fc7", 900) },
] as const;
---

<Layout title={t(l, "Activities", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "Activities", "title")}
    title={t(l, "Activities", "title")}
    subtitle={t(l, "Activities", "subtitle")}
    compact
  />

  <!-- On site -->
  <section class="section">
    <div class="container">
      <div class="section__head section__head--left">
        <h2>{t(l, "Activities", "onSiteTitle")}</h2>
      </div>
      <div class="onsite-grid">
        {
          onSite.map((item) => (
            <article class="onsite-card">
              <div class="onsite-card__icon" aria-hidden="true">
                {item.icon === "playground" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 20V10" />
                    <path d="M18 20V10" />
                    <path d="M4 10h16" />
                    <path d="M6 20h12" />
                    <path d="M9 14h6" />
                    <circle cx="12" cy="5" r="2" />
                  </svg>
                )}
                {item.icon === "fish" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6s-7.56-2.54-8.5-6Z" />
                    <path d="M18 12v.5" />
                    <path d="M16 17.93a9.77 9.77 0 0 1 0-11.86" />
                    <path d="M7 10.67C7 8 5.58 5.97 2.73 5.5c-1 1.5-1 5 .23 6.5-1.24 1.5-1.24 5-.23 6.5C5.58 18.03 7 16 7 13.33" />
                  </svg>
                )}
                {item.icon === "flame" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
                  </svg>
                )}
                {item.icon === "circle" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                )}
              </div>
              <h3>{t(l, "Activities", `${item.key}Title`)}</h3>
              <p>{t(l, "Activities", `${item.key}Description`)}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Nearby -->
  <section class="section">
    <div class="container">
      <div class="section__head section__head--left">
        <h2>{t(l, "Activities", "nearbyTitle")}</h2>
      </div>
      <div class="nearby-grid">
        {
          nearby.map((item) => (
            <article class="nearby-card">
              <div class="nearby-card__media">
                <img
                  src={item.image}
                  alt={t(l, "Activities", `${item.key}Title`)}
                  loading="lazy"
                />
              </div>
              <div class="nearby-card__body">
                <h3>{t(l, "Activities", `${item.key}Title`)}</h3>
                <p>{t(l, "Activities", `${item.key}Description`)}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  /* On-site cards */
  .onsite-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) {
    .onsite-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .onsite-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .onsite-card {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .onsite-card__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--color-white);
    color: var(--color-green);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-5);
  }
  .onsite-card__icon svg {
    width: 26px;
    height: 26px;
  }
  .onsite-card h3 {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-3);
  }
  .onsite-card p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }

  /* Nearby cards */
  .nearby-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 640px) {
    .nearby-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .nearby-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .nearby-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-hairline);
    background: var(--color-white);
  }
  .nearby-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .nearby-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .nearby-card__body {
    padding: var(--space-5);
  }
  .nearby-card h3 {
    font-size: var(--fs-md);
    margin-bottom: var(--space-2);
  }
  .nearby-card p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }
</style>
