---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const unsplash = (id: string, w = 1600) =>
  `https://images.unsplash.com/${id}?w=${w}&q=80&auto=format&fit=crop`;

const heroImage = "/images/old-gerlis-placeholder.webp";
const storyImage = unsplash("photo-1441974231531-c6227db76b6e", 1200);
const locationImage = unsplash("photo-1518655048521-f130df041f66", 1200);
---

<Layout title={t(l, "About", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "About", "title")}
    title={t(l, "About", "title")}
    subtitle={t(l, "About", "subtitle")}
    compact
  />

  <!-- Our story -->
  <section class="section">
    <div class="container alt">
      <div class="alt__media">
        <img src={storyImage} alt={t(l, "About", "storyTitle")} loading="lazy" />
      </div>
      <div class="alt__text">
        <h2>{t(l, "About", "storyTitle")}</h2>
        <p>{t(l, "About", "storyText1")}</p>
        <p>{t(l, "About", "storyText2")}</p>
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Sejerslev & Mors -->
  <section class="section">
    <div class="container alt alt--reverse">
      <div class="alt__media">
        <img src={locationImage} alt={t(l, "About", "locationTitle")} loading="lazy" />
      </div>
      <div class="alt__text">
        <h2>{t(l, "About", "locationTitle")}</h2>
        <p>{t(l, "About", "locationText1")}</p>
        <p>{t(l, "About", "locationText2")}</p>
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Values -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "About", "valuesTitle")}</h2>
      </div>
      <div class="values-grid">
        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 20A7 7 0 0 1 4 13V6a8 8 0 0 1 16 0v7a7 7 0 0 1-7 7Z" />
              <path d="M11 20c-5-2-7-6-7-10V6a8 8 0 0 1 8-2" />
            </svg>
          </div>
          <h3>{t(l, "About", "value1Title")}</h3>
          <p>{t(l, "About", "value1Description")}</p>
        </article>

        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <h3>{t(l, "About", "value2Title")}</h3>
          <p>{t(l, "About", "value2Description")}</p>
        </article>

        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m4.93 19.07 1.41-1.41" />
              <path d="m17.66 6.34 1.41-1.41" />
            </svg>
          </div>
          <h3>{t(l, "About", "value3Title")}</h3>
          <p>{t(l, "About", "value3Description")}</p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Alternating content blocks (shared pattern) */
  .alt {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 900px) {
    .alt {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
    .alt--reverse .alt__media {
      order: 2;
    }
  }
  .alt__media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }
  .alt__text h2 {
    font-size: var(--fs-2xl);
    margin-bottom: var(--space-5);
    text-wrap: balance;
  }
  .alt__text p {
    color: var(--color-muted);
    font-size: var(--fs-md);
    line-height: var(--lh-body);
    max-width: 52ch;
  }
  .alt__text p + p {
    margin-top: var(--space-4);
  }

  /* Values grid */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 768px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .value {
    background: var(--color-white);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .value__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
    margin-bottom: var(--space-5);
    background: var(--color-cream);
  }
  .value__icon svg {
    width: 26px;
    height: 26px;
  }
  .value h3 {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-3);
  }
  .value p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }
</style>
