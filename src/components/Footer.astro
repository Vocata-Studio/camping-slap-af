---
import { navLinks, bookingLink, localePath, t } from "../i18n/utils";
import type { Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const copyright = t(locale, "Footer", "copyright").replace("{year}", String(year));
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <button
        type="button"
        class="site-footer__brand-link"
        data-logo-toggle
        aria-label="Toggle logo variant (demo)"
        title="Click to switch logo variant"
      >
        <img
          src="/images/CSA-logo-w-flower.png"
          alt=""
          width="170"
          height="170"
          class="site-footer__logo"
          data-logo-img
        />
        <span class="site-footer__wordmark">Camping Slap Af</span>
      </button>
      <p class="site-footer__tagline">{t(locale, "Footer", "tagline")}</p>
    </div>

    <div class="site-footer__col">
      <h4 class="site-footer__heading">{t(locale, "Footer", "quickLinks")}</h4>
      <ul class="site-footer__links">
        {
          navLinks.map((link) => (
            <li>
              <a href={localePath(locale, link.href)} class="site-footer__link">
                {t(locale, "Header", link.key)}
              </a>
            </li>
          ))
        }
        <li>
          <a href={localePath(locale, bookingLink.href)} class="site-footer__link">
            {t(locale, "Header", bookingLink.key)}
          </a>
        </li>
      </ul>
    </div>

    <div class="site-footer__col">
      <h4 class="site-footer__heading">{t(locale, "Footer", "contactInfo")}</h4>
      <ul class="site-footer__contact">
        <li>{t(locale, "Footer", "address")}</li>
        <li>
          <a href={`tel:${t(locale, "Footer", "phone").replace(/\s+/g, "")}`} class="site-footer__link">
            {t(locale, "Footer", "phone")}
          </a>
        </li>
        <li>
          <a href={`mailto:${t(locale, "Footer", "email")}`} class="site-footer__link">
            {t(locale, "Footer", "email")}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__base">
    <div class="site-footer__base-inner">
      <p class="site-footer__copyright">{copyright}</p>
      <div class="site-footer__partners">
        <a href="https://www.dk-camp.dk" target="_blank" rel="noopener noreferrer" class="site-footer__dkcamp">
          <img
            src="/images/dk-camp-logo.png"
            alt={t(locale, "Footer", "dkCampAlt")}
            width="100"
            height="40"
            class="site-footer__dkcamp-logo"
          />
        </a>
        <a href="https://www.visitmors.dk/" target="_blank" rel="noopener noreferrer" class="site-footer__visitmors">
          <img
            src="/images/visitmors.dk-favicon.ico"
            alt={t(locale, "Footer", "visitMorsAlt")}
            width="40"
            height="40"
            class="site-footer__visitmors-logo"
          />
        </a>
      </div>
    </div>
  </div>
</footer>

<!-- Demo: toggle between logo variants by clicking the footer logo. Choice persists across pages. -->
<script is:inline>
  (function () {
    var STORAGE_KEY = "campingslapaf.logo";
    var VARIANTS = {
      flower: "/images/CSA-logo-w-flower.png",
      classic: "/csa-iconv1.png",
    };

    function getCurrent() {
      try {
        var v = localStorage.getItem(STORAGE_KEY);
        return v === "classic" ? "classic" : "flower";
      } catch (e) {
        return "flower";
      }
    }

    function apply(variant) {
      var src = VARIANTS[variant] || VARIANTS.flower;
      var imgs = document.querySelectorAll("[data-logo-img]");
      for (var i = 0; i < imgs.length; i++) {
        if (imgs[i].getAttribute("src") !== src) {
          imgs[i].setAttribute("src", src);
        }
      }
    }

    apply(getCurrent());

    var toggles = document.querySelectorAll("[data-logo-toggle]");
    for (var j = 0; j < toggles.length; j++) {
      toggles[j].addEventListener("click", function () {
        var next = getCurrent() === "flower" ? "classic" : "flower";
        try {
          localStorage.setItem(STORAGE_KEY, next);
        } catch (e) {}
        apply(next);
      });
    }
  })();
</script>

<style>
  .site-footer {
    margin-top: var(--space-16);
    border-top: 1px solid var(--color-hairline);
    background: var(--color-white);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding-top: var(--space-10);
    padding-bottom: var(--space-8);
  }

  .site-footer__brand-link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    color: var(--color-ink);
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }
  .site-footer__brand-link:hover {
    color: var(--color-ink);
  }
  .site-footer__brand-link:focus-visible {
    outline: 2px solid var(--color-green);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }
  .site-footer__logo {
    width: 170px;
    height: 170px;
    object-fit: contain;
    margin-bottom: -0.25rem;
  }
  .site-footer__wordmark {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.125rem;
  }
  .site-footer__tagline {
    margin-top: var(--space-3);
    color: var(--color-muted);
    max-width: 32ch;
  }

  .site-footer__heading {
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }

  .site-footer__links,
  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }

  .site-footer__link {
    color: var(--color-muted);
  }
  .site-footer__link:hover {
    color: var(--color-green);
  }

  .site-footer__base {
    border-top: 1px solid var(--color-hairline);
    padding-top: var(--space-5);
    padding-bottom: var(--space-6);
  }
  .site-footer__base-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .site-footer__copyright {
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }
  .site-footer__partners {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
  }
  .site-footer__dkcamp,
  .site-footer__visitmors {
    display: inline-block;
  }
  .site-footer__dkcamp-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    opacity: 0.8;
  }
  .site-footer__visitmors-logo {
    height: 40px;
    width: 40px;
    object-fit: contain;
    opacity: 0.8;
  }
  .site-footer__dkcamp:hover .site-footer__dkcamp-logo,
  .site-footer__visitmors:hover .site-footer__visitmors-logo {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: var(--space-10);
    }
  }
</style>
