---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t, localePath, bookingLink } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const heroImage = "/images/old-gerlis-placeholder.webp";

/** Locales that display EUR instead of DKK */
const eurLocales: Locale[] = ["de", "nl", "fr", "es", "it"];
const showEur = eurLocales.includes(l);

const accommodations = [
  { key: "campsite", gradient: 1 },
  { key: "camper", gradient: 2 },
  { key: "cottage", gradient: 1 },
  { key: "field", gradient: 2 },
  { key: "seasonal", gradient: 1 },
] as const;

const facilityKeys = [
  "facility1", "facility2", "facility3",
  "facility4", "facility5", "facility6",
  "facility7", "facility8", "facility9",
  "facility10", "facility11",
] as const;

const optionKeys = ["optionTowels", "optionBedding", "optionCleaning"] as const;
---

<Layout title={t(l, "Accommodation", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "Accommodation", "title")}
    title={t(l, "Accommodation", "title")}
    subtitle={t(l, "Accommodation", "subtitle")}
    compact
  />

  <!-- Price basis notice -->
  <section class="section section--tight">
    <div class="container">
      <div class="price-notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 16v-4" />
          <path d="M12 8h.01" />
        </svg>
        <p>{t(l, "Accommodation", "priceBasis")}</p>
      </div>
    </div>
  </section>

  <!-- Accommodation types -->
  <section class="section">
    <div class="container">
      <div class="acc-list">
        {
          accommodations.map((acc, index) => (
            <article class:list={["acc", index % 2 === 1 && "acc--reverse"]}>
              <div
                class:list={["acc__media", `acc__media--gradient-${acc.gradient}`]}
                role="img"
                aria-label={t(l, "Accommodation", acc.key)}
              >
                <span class="acc__media-label">Billede kommer snart</span>
              </div>
              <div class="acc__body">
                <h2>{t(l, "Accommodation", acc.key)}</h2>
                <p class="acc__description">
                  {t(l, "Accommodation", `${acc.key}Description`)}
                </p>
                <ul class="acc__features">
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{t(l, "Accommodation", `${acc.key}Feature1`)}</span>
                  </li>
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{t(l, "Accommodation", `${acc.key}Feature2`)}</span>
                  </li>
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{t(l, "Accommodation", `${acc.key}Feature3`)}</span>
                  </li>
                </ul>
                <div class="acc__meta">
                  <span class="acc__price">
                    {showEur ? t(l, "Accommodation", "priceTbaEur") : t(l, "Accommodation", "priceTba")}
                  </span>
                  <a href={localePath(l, bookingLink.href)} class="btn">
                    {t(l, "Accommodation", `${acc.key}BookCta`)}
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Optional extras -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "Accommodation", "optionsTitle")}</h2>
      </div>
      <ul class="options-list">
        {
          optionKeys.map((key) => (
            <li class="option-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{t(l, "Accommodation", key)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Dog friendly -->
  <section class="section">
    <div class="container">
      <div class="dog-friendly">
        <div class="dog-friendly__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5" />
            <path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5" />
            <path d="M8 14v.5" />
            <path d="M16 14v.5" />
            <path d="M11.25 16.25h1.5L12 17l-.75-.75Z" />
            <path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306" />
          </svg>
        </div>
        <div class="dog-friendly__text">
          <h3>{t(l, "Accommodation", "dogFriendlyTitle")}</h3>
          <p>{t(l, "Accommodation", "dogFriendlyText")}</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Shared facilities -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "Accommodation", "facilitiesTitle")}</h2>
        <p>{t(l, "Accommodation", "facilitiesDescription")}</p>
      </div>
      <ul class="facilities">
        {
          facilityKeys.map((key) => (
            <li class="facility">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{t(l, "Accommodation", key)}</span>
            </li>
          ))
        }
      </ul>
      <div class="bread-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a7 7 0 0 0-7 7c0 1.4.3 2.3.7 3-.3.5-.7 1.3-.7 2.5C5 16 6.5 17 8 17h8c1.5 0 3-1 3-2.5 0-1.2-.4-2-.7-2.5.4-.7.7-1.6.7-3a7 7 0 0 0-7-7Z" />
          <path d="M8 17v3" />
          <path d="M16 17v3" />
        </svg>
        <p>{t(l, "Accommodation", "breadNote")}</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Price notice */
  .section--tight {
    padding-bottom: 0;
  }
  .price-notice {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-cream);
    border-radius: var(--radius-md);
    max-width: 680px;
    margin-inline: auto;
  }
  .price-notice svg {
    width: 20px;
    height: 20px;
    color: var(--color-green);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .price-notice p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }

  .acc-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .acc {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 900px) {
    .acc {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-10);
    }
    .acc--reverse .acc__media {
      order: 2;
    }
  }

  .acc__media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .acc__media-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(26, 26, 26, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.5rem 1rem;
    border-radius: 999px;
  }
  .acc__media--gradient-1 {
    background:
      radial-gradient(at 20% 25%, #a8c9a5 0%, transparent 55%),
      radial-gradient(at 80% 80%, #d9e4cf 0%, transparent 60%),
      linear-gradient(135deg, #77BA8A 0%, #2B9854 100%);
  }
  .acc__media--gradient-2 {
    background:
      radial-gradient(at 75% 20%, #e8d9c0 0%, transparent 55%),
      radial-gradient(at 25% 85%, #9fb8a4 0%, transparent 60%),
      linear-gradient(160deg, #c8b99c 0%, #6b8b6e 100%);
  }

  .acc__body h2 {
    font-size: var(--fs-2xl);
    margin-bottom: var(--space-4);
  }
  .acc__description {
    color: var(--color-muted);
    font-size: var(--fs-md);
    line-height: var(--lh-body);
    max-width: 52ch;
    margin-bottom: var(--space-6);
  }

  .acc__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }
  .acc__features li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-ink);
    font-size: var(--fs-sm);
  }
  .acc__features svg {
    width: 18px;
    height: 18px;
    color: var(--color-green);
    flex-shrink: 0;
  }

  .acc__meta {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .acc__price {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-ink);
    font-size: var(--fs-md);
  }

  /* Options */
  .options-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 480px;
    margin-inline: auto;
  }
  @media (min-width: 640px) {
    .options-list {
      grid-template-columns: repeat(3, 1fr);
      max-width: 760px;
    }
  }
  .option-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: var(--color-cream);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    font-size: var(--fs-sm);
  }
  .option-item svg {
    width: 18px;
    height: 18px;
    color: var(--color-green);
    flex-shrink: 0;
  }

  /* Dog friendly */
  .dog-friendly {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    max-width: 680px;
    margin-inline: auto;
    padding: var(--space-7);
    background: var(--color-cream);
    border-radius: var(--radius-lg);
  }
  .dog-friendly__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--color-white);
    color: var(--color-green);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .dog-friendly__icon svg {
    width: 28px;
    height: 28px;
  }
  .dog-friendly h3 {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-2);
  }
  .dog-friendly p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }

  /* Facilities grid */
  .facilities {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 760px;
    margin-inline: auto;
  }
  @media (min-width: 640px) {
    .facilities {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4) var(--space-8);
    }
  }
  @media (min-width: 960px) {
    .facilities {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .facility {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: var(--color-cream);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    font-size: var(--fs-sm);
  }
  .facility svg {
    width: 18px;
    height: 18px;
    color: var(--color-green);
    flex-shrink: 0;
  }

  .bread-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-cream);
    border-radius: var(--radius-md);
    max-width: 680px;
    margin: var(--space-6) auto 0;
  }
  .bread-note svg {
    width: 22px;
    height: 22px;
    color: var(--color-green);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .bread-note p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }
</style>
