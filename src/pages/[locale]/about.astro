---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import { locales, isValidLocale, t } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect("/da");
const l = locale as Locale;

const heroImage = "/images/old-gerlis-placeholder.webp";
---

<Layout title={t(l, "About", "title")} locale={l}>
  <Hero
    image={heroImage}
    imageAlt={t(l, "About", "title")}
    title={t(l, "About", "title")}
    subtitle={t(l, "About", "subtitle")}
    compact
  />

  <!-- Our story -->
  <section class="section">
    <div class="container alt">
      <div class="alt__media alt__media--gradient-1" role="img" aria-label={t(l, "About", "storyTitle")}>
        <span class="alt__media-label">Billede kommer snart</span>
      </div>
      <div class="alt__text">
        <h2>{t(l, "About", "storyTitle")}</h2>
        <p>{t(l, "About", "storyText1")}</p>
        <p>{t(l, "About", "storyText2")}</p>
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Sejerslev & Mors -->
  <section class="section">
    <div class="container alt alt--reverse">
      <div class="alt__media alt__media--gradient-2" role="img" aria-label={t(l, "About", "locationTitle")}>
        <span class="alt__media-label">Billede kommer snart</span>
      </div>
      <div class="alt__text">
        <h2>{t(l, "About", "locationTitle")}</h2>
        <p>{t(l, "About", "locationText1")}</p>
        <p>{t(l, "About", "locationText2")}</p>
      </div>
    </div>
  </section>

  <hr class="hairline" />

  <!-- Values -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t(l, "About", "valuesTitle")}</h2>
      </div>
      <div class="values-grid">
        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 20h10" />
              <path d="M10 20c5.5-2.5.8-6.4 3-10" />
              <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z" />
              <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z" />
            </svg>
          </div>
          <h3>{t(l, "About", "value1Title")}</h3>
          <p>{t(l, "About", "value1Description")}</p>
        </article>

        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <h3>{t(l, "About", "value2Title")}</h3>
          <p>{t(l, "About", "value2Description")}</p>
        </article>

        <article class="value">
          <div class="value__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m4.93 19.07 1.41-1.41" />
              <path d="m17.66 6.34 1.41-1.41" />
            </svg>
          </div>
          <h3>{t(l, "About", "value3Title")}</h3>
          <p>{t(l, "About", "value3Description")}</p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Alternating content blocks (shared pattern) */
  .alt {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 900px) {
    .alt {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
    .alt--reverse .alt__media {
      order: 2;
    }
  }
  .alt__media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .alt__media-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(26, 26, 26, 0.22);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.5rem 1rem;
    border-radius: 999px;
  }
  .alt__media--gradient-1 {
    background:
      radial-gradient(at 20% 25%, #a8c9a5 0%, transparent 55%),
      radial-gradient(at 80% 80%, #d9e4cf 0%, transparent 60%),
      linear-gradient(135deg, #77BA8A 0%, #2B9854 100%);
  }
  .alt__media--gradient-2 {
    background:
      radial-gradient(at 75% 20%, #e8d9c0 0%, transparent 55%),
      radial-gradient(at 25% 85%, #9fb8a4 0%, transparent 60%),
      linear-gradient(160deg, #c8b99c 0%, #6b8b6e 100%);
  }
  .alt__text h2 {
    font-size: var(--fs-2xl);
    margin-bottom: var(--space-5);
    text-wrap: balance;
  }
  .alt__text p {
    color: var(--color-muted);
    font-size: var(--fs-md);
    line-height: var(--lh-body);
    max-width: 52ch;
  }
  .alt__text p + p {
    margin-top: var(--space-4);
  }

  /* Values grid */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 768px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .value {
    background: var(--color-white);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .value__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
    margin-bottom: var(--space-5);
    background: var(--color-cream);
  }
  .value__icon svg {
    width: 26px;
    height: 26px;
  }
  .value h3 {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-3);
  }
  .value p {
    color: var(--color-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }
</style>
